{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "height": 26,
  "modules-left": ["custom/logo"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["custom/updates", "custom/docker", "bluetooth", "network", "pulseaudio", "battery", "clock"],

  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{name}",
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": []
    }
  },

  "clock": {
    "format": "<b>{:%I:%M %p}</b>",
    "format-alt": "{:%B %d, %Y}",
    "tooltip": false
  },
  
  "custom/logo": {
    "format": "νΜ≠",
    "tooltip": false,
    "on-click": "walker"
  },

  "custom/updates": {
    "exec": "count=$(yay -Qu 2>/dev/null | wc -l); [ \"$count\" -gt 0 ] && echo \"σΑöΑ $count\" || exit 1",
    "interval": 300,
    "tooltip-format": "Updates available",
    "on-click": "hyprctl dispatch exec '[float;size 900 600;center] ghostty -e yay -Syu'"
  },

  "custom/docker": {
    "format": "σΑΓ®",
    "tooltip-format": "Running containers: {}",
    "exec": "docker ps -q | wc -l",
    "interval": 10,
    "on-click": "hyprctl dispatch exec '[float;size 900 600;center] ghostty -e lazydocker'"
  },

  "network": {
    "format": "σΑ•©",
    "format-wifi": "{icon}",
    "format-ethernet": "ETH",
    "format-disconnected": "X",
    "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
    "tooltip-format-wifi": "{essid}\nβ΅Θ{bandwidthDownBytes} β΅Γ{bandwidthUpBytes}",
    "tooltip-format-ethernet": "β΅Θ{bandwidthDownBytes} β΅Γ{bandwidthUpBytes}",
    "interval": 3,
    "on-click": "hyprctl dispatch exec '[float;size 900 600;center] ghostty -e impala'"
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "σΑùü",
    "format-icons": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"],
    "on-click": "hyprctl dispatch exec '[float;size 900 600;center] ghostty -e wiremix'",
    "scroll-step": 5
  },

  "battery": {
    "format": "{icon}",
    "format-charging": "{icon}",
    "format-full": "σΑ²Ö",
    "format-icons": {
      "charging": ["σΑΔ€", "σΑ²Ü", "σΑ²΅", "σΑ²à", "σΑΔù", "σΑ²â", "σΑΔû", "σΑ²ä", "σΑ²΄", "σΑ²Ö"],
      "default": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },
    "tooltip-format": "{capacity}% βÄΔ {power:.1f}W",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },

  "bluetooth": {
    "format": "σΑ²·",
    "format-disabled": "σΑ²≤",
    "format-connected": "σΑ²±",
    "tooltip-format": "{num_connections} connected",
    "on-click": "hyprctl dispatch exec '[float;size 900 600;center] ghostty -e bluetui'"
  }
}
