[global]
    ### Display ###
    monitor = 0
    follow = mouse

    ### Geometry ###
    width = 360
    height = 120
    origin = top-right
    offset = 6x6
    scale = 0
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_min_width = 320
    progress_bar_max_width = 320
    progress_bar_corner_radius = 4

    ### Appearance ###
    transparency = 0
    separator_height = 2
    padding = 14
    horizontal_padding = 16
    text_icon_padding = 14
    frame_width = 1
    frame_color = "#313244"
    gap_size = 8
    separator_color = frame
    sort = yes
    corner_radius = 5
    corners = all

    ### Text ###
    font = CaskaydiaMono Nerd Font Propo 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_theme = Papirus-Dark
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    icon_corner_radius = 6

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc/Advanced ###
    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    ignore_dbusclose = false

    ### Wayland ###
    layer = overlay
    force_xwayland = false

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all


[experimental]
    per_monitor_dpi = false


# --- Catppuccin Mocha ---

[urgency_low]
    background = "#181825"
    foreground = "#cdd6f4"
    frame_color = "#a6e3a1"
    timeout = 4
    #default_icon = dialog-information

[urgency_normal]
    background = "#181825"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 6
    #default_icon = dialog-information

[urgency_critical]
    background = "#181825"
    foreground = "#cdd6f4"
    frame_color = "#f38ba8"
    timeout = 0
    #default_icon = dialog-error
